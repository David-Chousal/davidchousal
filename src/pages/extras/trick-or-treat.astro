---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Trick or Treat — Extras — David Chousal" siteTone="cream">
  <div class="mx-auto w-full max-w-[min(1100px,calc(100vw-2rem))] pt-20 sm:pt-24">
    <header class="mb-8 text-center">
      <h1 class="font-pp-mori text-sm tracking-wide text-[#2a2520]/70">
        TRICK OR TREAT
      </h1>
      <p class="mt-3 text-sm leading-relaxed text-[#2a2520]/55">
        An interactive SVG scene. Click the moon.
      </p>
    </header>

    <div
      class="relative mx-auto w-full overflow-hidden rounded-[1.25rem] shadow-[0_24px_60px_-28px_rgba(42,37,32,0.2)] ring-1 ring-black/[0.08]"
      style="aspect-ratio: 1000 / 1320;"
    >
      <div
        id="trick-or-treat-mount"
        class="absolute inset-0 h-full w-full"
        aria-label="Interactive SVG animation — Trick or treat"
      />
    </div>
  </div>

  <script>
    import { mountHeroEmbed } from "../../lib/hero-embeds/loadHeroEmbed";

    const el = document.getElementById("trick-or-treat-mount");
    if (el) {
      mountHeroEmbed({ basePath: "/hero-embeds/trick-or-treat", mountEl: el }).catch((e) => {
        console.error(e);
        el.textContent = "Failed to load embed.";
      });
    }
  </script>
</Layout>

