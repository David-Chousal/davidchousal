---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Extras — David Chousal" siteTone="cream">
  <div class="mx-auto w-full max-w-2xl space-y-16 pt-20 sm:pt-24">
    <section class="space-y-6">
      <h1 class="font-pp-mori text-xs tracking-wide text-[#2a2520]/60">EXTRAS</h1>
      <p class="text-base leading-relaxed text-[#2a2520]/85">
        A place for writing, side projects, and interests that sit outside the main work grid.
      </p>
    </section>

    <section class="space-y-4">
      <h2 class="font-pp-mori text-xs tracking-wide text-[#2a2520]/60">WRITING</h2>
      <p class="text-sm text-[#2a2520]/50">Coming soon.</p>
    </section>

    <section class="space-y-4">
      <h2 class="font-pp-mori text-xs tracking-wide text-[#2a2520]/60">HOBBIES</h2>
      <p class="text-sm text-[#2a2520]/50">Coming soon.</p>
    </section>
  </div>

  <section
    class="mt-8 w-full border-t border-[#2a2520]/10 px-4 pb-24 pt-16"
    aria-label="Interactive extras"
  >
    <div class="mx-auto w-full max-w-[min(1000px,calc(100vw-2rem))]">
      <h2 class="font-pp-mori mb-6 text-center text-xs tracking-wide text-[#2a2520]/60">
        INTERACTIVE
      </h2>

      <div class="grid gap-4 sm:grid-cols-3">
        <a
          href="/extras/trick-or-treat"
          class="group rounded-xl border border-black/[0.08] bg-white/40 p-4 shadow-[0_18px_40px_-28px_rgba(42,37,32,0.25)] transition hover:bg-white/60"
        >
          <p class="font-pp-mori text-xs tracking-wide text-[#2a2520]/70">TRICK OR TREAT</p>
          <p class="mt-2 text-sm leading-relaxed text-[#2a2520]/55">
            Interactive SVG scene.
          </p>
          <p class="mt-3 text-xs text-[#2a2520]/40 group-hover:text-[#2a2520]/55">Open →</p>
        </a>

        <a
          href="/extras/svg-puzzle"
          class="group rounded-xl border border-black/[0.08] bg-white/40 p-4 shadow-[0_18px_40px_-28px_rgba(42,37,32,0.25)] transition hover:bg-white/60"
        >
          <p class="font-pp-mori text-xs tracking-wide text-[#2a2520]/70">SVG PUZZLE</p>
          <p class="mt-2 text-sm leading-relaxed text-[#2a2520]/55">
            Drag-and-snap puzzle pieces.
          </p>
          <p class="mt-3 text-xs text-[#2a2520]/40 group-hover:text-[#2a2520]/55">Open →</p>
        </a>

        <a
          href="/extras/pinocchio"
          class="group rounded-xl border border-black/[0.08] bg-white/40 p-4 shadow-[0_18px_40px_-28px_rgba(42,37,32,0.25)] transition hover:bg-white/60"
        >
          <p class="font-pp-mori text-xs tracking-wide text-[#2a2520]/70">PINOCCHIO</p>
          <p class="mt-2 text-sm leading-relaxed text-[#2a2520]/55">
            Pure CSS character + editable text.
          </p>
          <p class="mt-3 text-xs text-[#2a2520]/40 group-hover:text-[#2a2520]/55">Open →</p>
        </a>
      </div>
    </div>
  </section>
</Layout>
