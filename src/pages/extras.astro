---
import Layout from "../layouts/Layout.astro";
import { withBase } from "../lib/withBase";
---

<Layout title="Extras — David Chousal" siteTone="cream">
  <div class="mx-auto w-full max-w-2xl space-y-16 pt-20 sm:pt-24">
    <section class="space-y-6">
      <h1 class="font-pp-mori text-xs tracking-wide text-[#2a2520]/60">EXTRAS</h1>
      <p class="text-base leading-relaxed text-[#2a2520]/85">
        A place for writing, side projects, and interests that sit outside the main work grid.
      </p>
    </section>

    <section class="space-y-4">
      <h2 class="font-pp-mori text-xs tracking-wide text-[#2a2520]/60">WRITING</h2>
      <p class="text-sm text-[#2a2520]/50">Coming soon.</p>
    </section>

    <section class="space-y-4">
      <h2 class="font-pp-mori text-xs tracking-wide text-[#2a2520]/60">HOBBIES</h2>
      <p class="text-sm text-[#2a2520]/50">Coming soon.</p>
    </section>
  </div>

  <section
    class="mt-8 w-full border-t border-[#2a2520]/10 px-4 pb-24 pt-16"
    aria-label="Interactive SVG — Trick or treat"
  >
    <div class="mx-auto w-full max-w-[min(1000px,calc(100vw-2rem))]">
      <h2 class="font-pp-mori mb-6 text-center text-xs tracking-wide text-[#2a2520]/60">
        INTERACTIVE — TRICK OR TREAT
      </h2>
      <div
        class="relative mx-auto w-full max-w-full overflow-hidden rounded-[1.25rem] shadow-[0_24px_60px_-28px_rgba(42,37,32,0.2)] ring-1 ring-black/[0.08] aspect-[1000/1320]"
      >
        <iframe
          src={withBase("/hero-embeds/trick-or-treat/index.html")}
          title="Interactive SVG animation — Trick or treat"
          class="absolute inset-0 block h-full w-full border-0"
          loading="lazy"
          referrerpolicy="strict-origin-when-cross-origin"
        />
      </div>
    </div>
  </section>
</Layout>
