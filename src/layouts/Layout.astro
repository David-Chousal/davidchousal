---
interface Props {
  title?: string;
  /** Warm cream tone + header tweaks for hero-first pages */
  siteTone?: "default" | "cream";
  /** Case study pages ship their own chrome (sidebar, bottom nav). */
  variant?: "default" | "caseStudy";
  /** Overrides default meta description when set */
  description?: string;
  /** PWA-style theme color (case study canvas) */
  themeColor?: string;
}

import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { withBase } from "../lib/withBase";

const {
  title = "David Chousal",
  siteTone = "default",
  variant = "default",
  description,
  themeColor,
} = Astro.props;
const isCaseStudy = variant === "caseStudy";
const isCream = siteTone === "cream";
const nav = [
  { label: "Work", href: withBase("/") },
  { label: "About", href: withBase("/about") },
  { label: "Extras", href: withBase("/extras") },
];
const currentPath = Astro.url.pathname;

const navLinkCream = (href: string) =>
  [
    "text-xs transition-colors",
    currentPath === href
      ? "font-medium text-[#2a2520]/90"
      : "text-[#2a2520]/55 hover:text-[#2a2520]/85",
  ] as const;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={description ?? "David Chousal — portfolio"}
    />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <ClientRouter />
    {(themeColor || isCream) && <meta name="theme-color" content={themeColor ?? "#f5f1ec"} />}
    {
      (isCaseStudy || isCream) && (
        <>
          <link rel="preconnect" href="https://fonts.googleapis.com" />
          <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
          <link
            href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=IBM+Plex+Mono:wght@400;500&display=swap"
            rel="stylesheet"
          />
        </>
      )
    }
  </head>
  <body
    class:list={[
      "antialiased min-h-screen",
      !isCaseStudy && "flex flex-col",
      isCaseStudy && "overflow-x-hidden bg-case-canvas text-case-ink",
      !isCaseStudy &&
        (isCream
          ? "overflow-x-hidden bg-[#f5f1ec] text-[#2a2520] font-landing-sans"
          : "bg-white text-gray-900"),
    ]}
  >
    {isCaseStudy ? (
      <slot />
    ) : (
      <>
        {isCream ? (
          <header class="fixed top-0 left-0 right-0 z-50 bg-[#f5f1ec]/80 backdrop-blur-sm">
            <div class="mx-auto w-full max-w-[900px] px-4 py-4 sm:w-[70vw]">
              <div class="hidden items-start sm:grid sm:grid-cols-3">
                <a
                  href={withBase("/")}
                  class="group justify-self-start transition-opacity hover:opacity-70"
                >
                  <h1 class="font-case-sans text-xs font-bold tracking-tight leading-none text-[#2a2520]">
                    DAVID CHOUSAL
                  </h1>
                  <p
                    class="font-case-sans mt-2.5 text-xs font-normal uppercase tracking-[0.18em] text-[#2a2520]/60 transition-opacity duration-200"
                  >
                    Computer engineer
                  </p>
                </a>
                <nav class="justify-self-center">
                  <ul class="flex items-center gap-6">
                    {nav.map(({ label, href }) => (
                      <li>
                        <a href={href} class:list={navLinkCream(href)}>
                          {label.toUpperCase()}
                        </a>
                      </li>
                    ))}
                  </ul>
                </nav>
                <div class="flex items-center justify-end gap-6 justify-self-end">
                  <a
                    href="https://www.linkedin.com/in/david-chousal-749010297/"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="LinkedIn"
                    class="text-[#2a2520]/45 transition-colors hover:text-[#2a2520]/75"
                  >
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                      <rect x="2" y="9" width="4" height="12" />
                      <circle cx="4" cy="4" r="2" />
                    </svg>
                  </a>
                  <a
                    href="https://github.com/David-Chousal"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="GitHub"
                    class="text-[#2a2520]/45 transition-colors hover:text-[#2a2520]/75"
                  >
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                    </svg>
                  </a>
                  <a
                    href="mailto:davidchousal@icloud.com"
                    aria-label="Email"
                    class="text-[#2a2520]/45 transition-colors hover:text-[#2a2520]/75"
                  >
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <rect width="20" height="16" x="2" y="4" rx="2" />
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                    </svg>
                  </a>
                </div>
              </div>
              <div class="sm:hidden">
                <div class="flex flex-col gap-4">
                  <div class="flex items-start justify-between gap-4">
                    <a href={withBase("/")} class="group min-w-0 transition-opacity hover:opacity-70">
                      <h1 class="font-case-sans text-sm font-bold tracking-tight leading-none text-[#2a2520]">
                        DAVID CHOUSAL
                      </h1>
                      <p class="font-case-sans mt-2 text-xs font-normal uppercase tracking-[0.18em] text-[#2a2520]/60">
                        Computer engineer
                      </p>
                    </a>
                  </div>
                  <nav>
                    <ul class="flex flex-wrap gap-x-5 gap-y-2">
                      {nav.map(({ label, href }) => (
                        <li>
                          <a href={href} class:list={navLinkCream(href)}>
                            {label.toUpperCase()}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </nav>
                  <div class="flex items-center gap-6">
                    <a
                      href="https://www.linkedin.com/in/david-chousal-749010297/"
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label="LinkedIn"
                      class="text-[#2a2520]/45 transition-colors hover:text-[#2a2520]/75"
                    >
                      <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                        <rect x="2" y="9" width="4" height="12" />
                        <circle cx="4" cy="4" r="2" />
                      </svg>
                    </a>
                    <a
                      href="https://github.com/David-Chousal"
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label="GitHub"
                      class="text-[#2a2520]/45 transition-colors hover:text-[#2a2520]/75"
                    >
                      <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                      </svg>
                    </a>
                    <a
                      href="mailto:davidchousal@icloud.com"
                      aria-label="Email"
                      class="text-[#2a2520]/45 transition-colors hover:text-[#2a2520]/75"
                    >
                      <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <rect width="20" height="16" x="2" y="4" rx="2" />
                        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                      </svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </header>
        ) : (
          <header
            class:list={[
              "flex items-center justify-between border-b border-gray-100 px-6 py-6 md:px-12",
            ]}
          >
            <a href={withBase("/")} class="text-sm font-medium tracking-tight transition-opacity hover:opacity-60">
              <span class="block">David Chousal</span>
            </a>
            <div class="flex items-center gap-6">
              <nav>
                <ul class="flex gap-6">
                  {nav.map(({ label, href }) => (
                    <li>
                      <a
                        href={href}
                        class:list={[
                          "text-sm transition-opacity hover:opacity-60",
                          currentPath === href ? "font-medium opacity-100" : "opacity-50",
                        ]}
                      >
                        {label}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
              <div class="flex items-center gap-3 border-l border-gray-200 pl-4">
                <a
                  href="https://github.com/David-Chousal"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="GitHub"
                  class="text-gray-400 transition-colors hover:text-gray-900"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z" />
                  </svg>
                </a>
                <a
                  href="https://www.linkedin.com/in/david-chousal-749010297/"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="LinkedIn"
                  class="text-gray-400 transition-colors hover:text-gray-900"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                  </svg>
                </a>
                <a
                  href="mailto:davidchousal@icloud.com"
                  aria-label="Email"
                  class="text-gray-400 transition-colors hover:text-gray-900"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z" />
                  </svg>
                </a>
              </div>
            </div>
          </header>
        )}

        <slot name="hero" />

        <div
          class:list={[
            /* Cream home: avoid flex-1 + flex-basis 0 collapsing the work grid in column flex layouts. */
            !isCream && "flex-1",
            isCream
              ? "relative z-10 mx-auto w-full flex-shrink-0 px-4 py-12 sm:w-[70vw] sm:max-w-[900px]"
              : "px-6 py-12 md:px-12",
          ]}
          id="site-content"
        >
          <slot />
        </div>

        <footer
          class:list={[
            isCream
              ? "mx-auto w-full max-w-[900px] px-4 pb-10 pt-2 sm:w-[70vw]"
              : "border-t border-gray-100 px-6 py-6 md:px-12",
          ]}
        >
          {isCream ? (
            <>
              <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 border-t border-black/[0.06] py-6">
                <a
                  href={withBase("/")}
                  class:list={[
                    "text-[11px] tracking-wide transition-colors",
                    currentPath === withBase("/")
                      ? "font-medium text-[#2a2520]/80"
                      : "text-[#2a2520]/35 hover:text-[#2a2520]/65",
                  ]}
                >
                  HOME
                </a>
                <a
                  href={withBase("/#projects-grid")}
                  class="text-[11px] tracking-wide text-[#2a2520]/35 transition-colors hover:text-[#2a2520]/65"
                >
                  WORK
                </a>
                <a
                  href={withBase("/about")}
                  class="text-[11px] tracking-wide text-[#2a2520]/35 transition-colors hover:text-[#2a2520]/65"
                >
                  ABOUT
                </a>
                <a
                  href={withBase("/extras")}
                  class="text-[11px] tracking-wide text-[#2a2520]/35 transition-colors hover:text-[#2a2520]/65"
                >
                  EXTRAS
                </a>
              </div>
              <p class="text-center text-xs text-[#2a2520]/40">
                &copy; {new Date().getFullYear()} David Chousal
              </p>
            </>
          ) : (
            <p class="text-xs text-gray-400">&copy; {new Date().getFullYear()} David Chousal</p>
          )}
        </footer>
      </>
    )}
  </body>
</html>
