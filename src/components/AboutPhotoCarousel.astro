---
export interface AboutCarouselSlide {
  src: string;
  alt: string;
}

interface Props {
  slides: AboutCarouselSlide[];
}

const { slides } = Astro.props;
---

<div
  class="space-y-4"
  data-about-carousel
  role="region"
  aria-roledescription="carousel"
  aria-label="Photos"
  tabindex="0"
>
  <h2 class="font-pp-mori text-xs tracking-wide text-[#2a2520]/60">PHOTOS</h2>

  <div
    class="overflow-hidden rounded-sm ring-1 ring-black/[0.06] shadow-[0_14px_40px_-22px_rgba(42,37,32,0.14)]"
    data-about-carousel-viewport
  >
    <div class="relative aspect-[4/3] w-full bg-black/[0.03]">
      {
        slides.map((slide, i) => (
          <div
            class:list={[
              "absolute inset-0 transition-opacity duration-300 ease-out",
              i === 0 ? "z-10 opacity-100" : "z-0 opacity-0 pointer-events-none",
            ]}
            data-about-slide-panel
            role="group"
            aria-roledescription="slide"
            aria-label={`${i + 1} of ${slides.length}`}
            aria-hidden={i === 0 ? "false" : "true"}
            inert={i !== 0 ? true : undefined}
          >
            <img
              src={slide.src}
              alt={slide.alt}
              class="h-full w-full object-cover"
              loading={i === 0 ? "eager" : "lazy"}
              decoding="async"
              draggable="false"
            />
          </div>
        ))
      }
    </div>
  </div>

  <div class="flex flex-wrap items-center justify-center gap-2 px-0.5" role="toolbar" aria-label="Carousel controls">
    <button
      type="button"
      class="-m-1 inline-flex shrink-0 items-center justify-center p-1 text-[#2a2520]/55 transition-colors hover:text-[#2a2520]/85 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#2a2520]/35 disabled:opacity-35"
      data-about-carousel-prev
      aria-label="Previous photo"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 18l-6-6 6-6"></path>
      </svg>
    </button>
    <div class="flex flex-wrap justify-center gap-1.5" role="tablist" aria-label="Slides">
      {
        slides.map((slide, i) => (
          <button
            type="button"
            class:list={[
              "h-2 w-2 rounded-full transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#2a2520]/35",
              i === 0 ? "bg-[#2a2520]/70" : "bg-[#2a2520]/20 hover:bg-[#2a2520]/40",
            ]}
            data-about-carousel-dot
            data-slide-index={i}
            aria-label={`Photo ${i + 1}: ${slide.alt}`}
            aria-selected={i === 0 ? "true" : "false"}
            role="tab"
            tabindex={i === 0 ? 0 : -1}
          />
        ))
      }
    </div>
    <button
      type="button"
      class="-m-1 inline-flex shrink-0 items-center justify-center p-1 text-[#2a2520]/55 transition-colors hover:text-[#2a2520]/85 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#2a2520]/35 disabled:opacity-35"
      data-about-carousel-next
      aria-label="Next photo"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"></path>
      </svg>
    </button>
  </div>

  <p class="sr-only" data-about-carousel-live aria-live="polite" aria-atomic="true"></p>
</div>

<script>
  function bindAboutCarousels() {
    document.querySelectorAll("[data-about-carousel]").forEach((root) => {
      if (!(root instanceof HTMLElement)) return;
      if (root.dataset.aboutBound === "1") return;
      root.dataset.aboutBound = "1";

      const panels = [...root.querySelectorAll("[data-about-slide-panel]")];
      const dots = [...root.querySelectorAll("[data-about-carousel-dot]")];
      const prevBtn = root.querySelector("[data-about-carousel-prev]");
      const nextBtn = root.querySelector("[data-about-carousel-next]");
      const live = root.querySelector("[data-about-carousel-live]");

      if (
        !panels.length ||
        !(prevBtn instanceof HTMLButtonElement) ||
        !(nextBtn instanceof HTMLButtonElement)
      )
        return;

      let index = 0;
      const n = panels.length;

      function announce() {
        if (!(live instanceof HTMLElement)) return;
        const img = panels[index] && panels[index].querySelector("img");
        const alt = (img && img.getAttribute("alt")) || "";
        live.textContent = `Slide ${index + 1} of ${n}. ${alt}`;
      }

      function setIndex(next: number) {
        index = ((next % n) + n) % n;
        panels.forEach((panel, i) => {
          if (!(panel instanceof HTMLElement)) return;
          const on = i === index;
          panel.classList.toggle("opacity-100", on);
          panel.classList.toggle("z-10", on);
          panel.classList.toggle("opacity-0", !on);
          panel.classList.toggle("z-0", !on);
          panel.classList.toggle("pointer-events-none", !on);
          panel.setAttribute("aria-hidden", on ? "false" : "true");
          if (on) panel.removeAttribute("inert");
          else panel.setAttribute("inert", "");
        });
        dots.forEach((dot, i) => {
          if (!(dot instanceof HTMLButtonElement)) return;
          const on = i === index;
          dot.setAttribute("aria-selected", on ? "true" : "false");
          dot.tabIndex = on ? 0 : -1;
          dot.classList.toggle("bg-[#2a2520]/70", on);
          dot.classList.toggle("bg-[#2a2520]/20", !on);
          dot.classList.toggle("hover:bg-[#2a2520]/40", !on);
        });
        prevBtn.disabled = n <= 1;
        nextBtn.disabled = n <= 1;
        announce();
      }

      prevBtn.addEventListener("click", () => setIndex(index - 1));
      nextBtn.addEventListener("click", () => setIndex(index + 1));
      dots.forEach((dot, i) => {
        if (dot instanceof HTMLButtonElement) dot.addEventListener("click", () => setIndex(i));
      });

      root.addEventListener("keydown", (e) => {
        if (e.key === "ArrowLeft") {
          e.preventDefault();
          setIndex(index - 1);
        } else if (e.key === "ArrowRight") {
          e.preventDefault();
          setIndex(index + 1);
        } else if (e.key === "Home") {
          e.preventDefault();
          setIndex(0);
        } else if (e.key === "End") {
          e.preventDefault();
          setIndex(n - 1);
        }
      });

      setIndex(0);
    });
  }

  bindAboutCarousels();
  document.addEventListener("astro:page-load", bindAboutCarousels);
</script>
