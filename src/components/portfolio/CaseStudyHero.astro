---
interface Video {
  url: string;
  title: string;
}

interface Props {
  title: string;
  description: string;
  tags: string[];
  year?: string | number;
  logo?: string;
  heroVideos?: Video[];
  thumbnail: string;
  /** Full-bleed texture/photo inside the pill (same field as homepage card hover frame). */
  pillAmbientBgUrl?: string;
}

const { title, description, tags, year, logo, heroVideos, thumbnail, pillAmbientBgUrl } = Astro.props;

const pillAmbientStyle = pillAmbientBgUrl
  ? { backgroundImage: `url("${pillAmbientBgUrl.replace(/"/g, "%22")}")` }
  : undefined;

const isYouTubeUrl = (url: string): boolean =>
  url.includes("youtube.com") || url.includes("youtu.be");

const isVideoUrl = (url: string): boolean =>
  [".mp4", ".webm", ".ogg", ".mov"].some((ext) => url.toLowerCase().endsWith(ext));

const getYouTubeEmbedId = (url: string): string => {
  const match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&/?\s]+)/);
  return match ? match[1] : "";
};

const getEmbedUrl = (url: string): string =>
  `https://www.youtube.com/embed/${getYouTubeEmbedId(url)}`;

const slides = heroVideos && heroVideos.length > 0 ? heroVideos : null;
const yearStr = year != null ? String(year) : "";
---

<section class="w-full p-4 pt-20 md:pt-8">
  <div class="flex w-full flex-col gap-6 md:flex-row md:justify-between md:gap-8">
    <div class="min-w-0 flex-1">
      <div class="mb-2 flex flex-wrap items-center gap-2 md:mb-3">
        <h3 class="font-case-sans text-sm font-medium leading-none tracking-tight text-case-ink/80 md:text-base">
          {title}
        </h3>
        {
          logo && (
            <img src={logo} alt="" class="h-[14px] w-auto shrink-0 object-contain md:h-4" width="80" height="16" />
          )
        }
      </div>
      <p class="font-case-sans text-xs leading-relaxed text-case-ink/60 md:text-sm">
        {description}
      </p>
    </div>
    <div class="flex flex-row items-start justify-between gap-2 md:flex-col md:items-end md:justify-start">
      <div class="flex flex-wrap gap-1.5 justify-start md:justify-end md:gap-2">
        {
          tags.map((tag) => (
            <span class="case-study-pill font-case-mono text-[10px] text-case-ink/40 md:text-xs">
              {tag}
            </span>
          ))
        }
      </div>
      {yearStr && <span class="font-case-mono mt-0 text-[10px] text-case-ink/30 md:mt-1 md:text-xs">{yearStr}</span>}
    </div>
  </div>

  <div class="flex flex-shrink-0 flex-col items-center justify-center pb-2 pt-4 md:px-6 md:pt-8">
    <div data-hero-carousel class="flex w-full max-w-4xl flex-col items-center gap-3">
      <div class="relative flex w-full items-center justify-center px-1 sm:px-0">
        <div
          class="relative isolate aspect-[4.01/3] w-full max-w-4xl overflow-hidden rounded-[1.75rem] shadow-[0_14px_40px_-22px_rgba(42,37,32,0.14)] ring-1 ring-black/[0.06]"
        >
          {
            pillAmbientBgUrl ? (
              <div
                class="pointer-events-none absolute inset-0 z-0 bg-cover bg-center"
                style={pillAmbientStyle}
                aria-hidden="true"
              />
            ) : (
              <div class="pointer-events-none absolute inset-0 z-0 bg-[#e6e4e1]" aria-hidden="true" />
            )
          }
          {
            pillAmbientBgUrl && (
              <div
                class="pointer-events-none absolute inset-0 z-[1] bg-gradient-to-b from-black/[0.06] via-transparent to-black/[0.14]"
                aria-hidden="true"
              />
            )
          }
          <div
            class="pointer-events-none absolute inset-0 z-[2] shadow-[inset_0_1px_0_rgba(255,255,255,0.28)]"
            aria-hidden="true"
          />

          <!-- Stage fills the pill; media uses % of this box (not vh) so portrait sims stay inside aspect-[4.01/3]. -->
          <div
            class="absolute inset-0 z-10 flex min-h-0 min-w-0 items-center justify-center px-[5%] py-[6%] sm:px-[6%] sm:py-[7%]"
          >
            <div class="relative h-full min-h-0 w-full min-w-0">
              {
                slides ? (
                  slides.map((video, index) => (
                    <div
                      class:list={[
                        "hero-slide absolute inset-0 flex min-h-0 min-w-0 items-center justify-center overflow-hidden",
                        index !== 0 && "hidden",
                      ]}
                      data-hero-slide={index}
                    >
                      {isYouTubeUrl(video.url) && (
                        <div class="aspect-video h-auto max-h-full w-full max-w-full overflow-hidden rounded-md shadow-[0_16px_48px_-12px_rgba(0,0,0,0.35)] ring-1 ring-black/10">
                          <iframe
                            src={getEmbedUrl(video.url)}
                            title={video.title}
                            class="h-full w-full"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                            allowfullscreen
                          />
                        </div>
                      )}
                      {isVideoUrl(video.url) && (
                        <video
                          src={video.url}
                          title={video.title}
                          class="h-auto max-h-full w-auto max-w-full rounded-md object-contain shadow-[0_16px_48px_-12px_rgba(0,0,0,0.35)] ring-1 ring-black/10"
                          muted
                          playsinline
                          autoplay
                          loop
                          preload="metadata"
                        />
                      )}
                      {!isYouTubeUrl(video.url) && !isVideoUrl(video.url) && (
                        <img
                          src={thumbnail}
                          alt={video.title}
                          class="h-auto max-h-full w-auto max-w-full rounded-md object-contain shadow-[0_16px_48px_-12px_rgba(0,0,0,0.35)] ring-1 ring-black/10"
                          loading="lazy"
                        />
                      )}
                    </div>
                  ))
                ) : (
                  <div class="flex h-full min-h-0 w-full items-center justify-center">
                    <img
                      src={thumbnail}
                      alt={title}
                      class="h-auto max-h-full w-auto max-w-full rounded-md object-contain shadow-[0_16px_48px_-12px_rgba(0,0,0,0.35)] ring-1 ring-black/10"
                      loading="eager"
                    />
                  </div>
                )
              }
            </div>
          </div>
        </div>
      </div>

      {
        slides && slides.length > 1 && (
          <div class="flex items-center justify-center gap-1 py-1">
            <button
              type="button"
              data-hero-prev
              class="flex items-center justify-center rounded border-0 bg-transparent p-1.5 text-case-ink/40 transition hover:scale-110 active:scale-95"
              aria-label="Previous slide"
            >
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                <path d="M6 2L3 5L6 8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
            <div class="flex items-center gap-0.5" data-hero-dots>
              {slides.map((_, i) => (
                <button
                  type="button"
                  data-hero-dot={String(i)}
                  data-on={i === 0 ? "true" : "false"}
                  class="flex items-center justify-center rounded border-0 bg-transparent p-2 transition hover:scale-110 active:scale-95"
                  aria-label={`View slide ${i + 1}`}
                  title={`Slide ${i + 1}`}
                >
                  <span class="hero-dot-inner block h-2 w-2 shrink-0 rounded-full bg-case-ink/20 transition-all duration-300" data-hero-dot-inner />
                </button>
              ))}
            </div>
            <button
              type="button"
              data-hero-next
              class="flex items-center justify-center rounded border-0 bg-transparent p-1.5 text-case-ink/40 transition hover:scale-110 active:scale-95"
              aria-label="Next slide"
            >
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                <path d="M4 2L7 5L4 8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          </div>
        )
      }
    </div>
  </div>
</section>
