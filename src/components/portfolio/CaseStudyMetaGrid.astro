---
interface Props {
  role?: string;
  roles?: string[];
  duration?: string;
  skills?: string[];
  technologies?: string[];
  tools?: string;
  team?: string[];
}

const { role, roles, duration, skills, technologies, tools, team } = Astro.props;

const roleLines =
  roles && roles.length > 0 ? roles : role ? [role] : [];

const skillLines =
  skills && skills.length > 0
    ? skills
    : technologies && technologies.length > 0
      ? technologies
      : [];

const columns: { key: string; label: string; lines: string[] }[] = [];
if (roleLines.length) columns.push({ key: "role", label: "Role", lines: roleLines });
if (duration) columns.push({ key: "duration", label: "Duration", lines: [duration] });
if (skillLines.length) columns.push({ key: "skills", label: "Skills", lines: skillLines });
if (tools) columns.push({ key: "tools", label: "Tool", lines: [tools] });
if (team && team.length) columns.push({ key: "team", label: "Team", lines: team });
---

{
  columns.length > 0 && (
    <div
      class:list={[
        "grid gap-4 md:gap-6",
        columns.length <= 2 && "grid-cols-2",
        columns.length === 3 && "grid-cols-2 md:grid-cols-3",
        columns.length >= 4 && "grid-cols-2 md:grid-cols-3 lg:grid-cols-5",
      ]}
    >
      {columns.map((col) => (
        <div class="space-y-1.5 md:space-y-2">
          <h3 class="font-case-mono text-[10px] uppercase text-case-ink/50 md:text-xs">
            {col.label}
          </h3>
          <div class="space-y-0.5 md:space-y-1">
            {col.lines.map((line) => (
              <p class="font-case-sans text-xs text-case-ink/80 md:text-sm">{line}</p>
            ))}
          </div>
        </div>
      ))}
    </div>
  )
}
