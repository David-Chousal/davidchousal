---
interface Props {
  role?: string;
  technologies?: string[];
  tags?: string[];
}

const { role, technologies, tags } = Astro.props;
---

<section class="py-6 border-t border-gray-200">
  {role && (
    <div class="mb-4">
      <h3 class="text-sm font-semibold text-gray-600 uppercase tracking-wide mb-2">Role</h3>
      <p class="text-lg text-gray-800">{role}</p>
    </div>
  )}

  {(technologies && technologies.length > 0) && (
    <div class="mb-4">
      <h3 class="text-sm font-semibold text-gray-600 uppercase tracking-wide mb-2">Technologies</h3>
      <div class="flex flex-wrap gap-2">
        {technologies.map((tech) => (
          <span class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm font-medium">
            {tech}
          </span>
        ))}
      </div>
    </div>
  )}

  {(tags && tags.length > 0) && (
    <div>
      <h3 class="text-sm font-semibold text-gray-600 uppercase tracking-wide mb-2">Tags</h3>
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="px-2 py-1 bg-gray-200 text-gray-700 rounded text-xs font-medium">
            {tag}
          </span>
        ))}
      </div>
    </div>
  )}
</section>
